    local recoilEnabled   = false
    local recoilX         = 0.0
    local recoilY         = 0.0
    local recoilOriginals = {}   -- "weaponName_folderName" -> { [addr] = originalValue }
    local _recoilLast     = nil

    local function getEquippedWeapon()
        local ok, name = pcall(function()
            return game.ReplicatedStorage
                :FindFirstChild("Players")
                :FindFirstChild(LocalPlayer.Name)
                :FindFirstChild("Status")
                :FindFirstChild("GameplayVariables")
                :FindFirstChild("EquippedTool").Value
        end)
        return (ok and name and name ~= "") and name or nil
    end

    local VALUE_OFFSET = 0xD0

    -- mirrors the working script: memory_write("double", inner.Address + VALUE_OFFSET, val)
    local function writeAxis(axis, value)
        pcall(function()
            memory_write("double", axis.Address + VALUE_OFFSET, value)
        end)
    end

    local function readAxis(axis)
        -- read via Lua property (reliable for reading originals)
        local ok, v = pcall(function() return axis.Value end)
        return ok and type(v) == "number" and v or nil
    end

    -- iterates BoolValue folders inside a recoil folder and calls fn(axis)
    -- structure: RecoilPattern > BoolValue > NumberValue (x, y)
    local function forEachAxis(pattern, fn)
        if not pattern then return end
        for _, shot in ipairs(pattern:GetChildren()) do
            if shot.ClassName == "BoolValue" then
                for _, axis in ipairs(shot:GetChildren()) do
                    if axis.ClassName == "NumberValue" then
                        fn(axis)
                    end
                end
            end
        end
    end

    local RECOIL_FOLDERS = { "RecoilPattern", "RecoilPattern2" }

    local function applyRecoil(weaponName)
        if not recoilEnabled or not weaponName then return end
        local wFolder = game.ReplicatedStorage.RangedWeapons:FindFirstChild(weaponName)
        if not wFolder then return end

        for _, folderName in ipairs(RECOIL_FOLDERS) do
            local pattern = wFolder:FindFirstChild(folderName)
            if not pattern then continue end

            local key = weaponName .. "_" .. folderName

            -- save originals once using Lua property read (safe, no memory needed)
            if not recoilOriginals[key] then
                local orig = {}
                forEachAxis(pattern, function(axis)
                    local v = readAxis(axis)
                    if v ~= nil then orig[axis.Name] = v end
                end)
                recoilOriginals[key] = orig
            end

            -- write via memory_write — bypasses server replication
            forEachAxis(pattern, function(axis)
                local n = axis.Name
                if n == "x" then
                    writeAxis(axis, recoilX)
                elseif n == "y" then
                    writeAxis(axis, recoilY)
                end
            end)
        end
    end

    local function restoreRecoil(weaponName)
        if not weaponName then return end
        local wFolder = game.ReplicatedStorage.RangedWeapons:FindFirstChild(weaponName)
        if not wFolder then return end

        for _, folderName in ipairs(RECOIL_FOLDERS) do
            local pattern = wFolder:FindFirstChild(folderName)
            if not pattern then continue end

            local key = weaponName .. "_" .. folderName
            local orig = recoilOriginals[key]
            if not orig then continue end

            forEachAxis(pattern, function(axis)
                local saved = orig[axis.Name]
                if saved ~= nil then writeAxis(axis, saved) end
            end)
            recoilOriginals[key] = nil
        end
    end

