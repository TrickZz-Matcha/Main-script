-- ── SETTERS ───────────────────────────────────────────────────────────────────
-- When toggling OFF: immediately hide all Drawing objects and clear the cfg state
-- so labels vanish on the exact frame the toggle fires.
-- When toggling ON: immediately run a scan so labels appear without waiting for
-- the Heartbeat timer (which could be up to 2s away for containers).
local function hideAll(cfg)
    -- hide every slot in the pool regardless of a2s state
    local pool = cfg.pool
    for i = 1, #pool do
        local slot = pool[i]
        slot.lbl.Visible = false
        slot.tr.Visible  = false
        if slot.sub then for j = 1, MAX_SUB do slot.sub[j].Visible = false end end
        if slot.addr then freeSlot(slot) end
    end
    tclear(cfg.a2s)
    local c = cfg.cache[1]; for i = 1, #c do c[i] = nil end
    local cl = cfg._clean;  for i = 1, #cl do cl[i] = nil end
end

local function setContainer(v)
    ContainerESPEnabled = v; ContainerCfg.on = v
    if not v then hideAll(ContainerCfg)
    else tclear(posCache); doScan(ContainerCfg) end
end
local function setDropped(v)
    DroppedESPEnabled = v; DroppedCfg.on = v
    if not v then hideAll(DroppedCfg) else doScan(DroppedCfg) end
end
local function setDead(v)
    DeadBodyESPEnabled = v; DeadCfg.on = v
    if not v then hideAll(DeadCfg) else doScan(DeadCfg) end
end
local function setExit(v)
    ExitESPEnabled = v; ExitCfg.on = v
    if not v then hideAll(ExitCfg) else doScan(ExitCfg) end
end
local function setBoss(v)
    BossESPEnabled = v; BossCfg.on = v
    if not v then hideAll(BossCfg) else doScan(BossCfg) end
end

-- ── CHILDVM WATCHERS ──────────────────────────────────────────────────────────
local function cvClaim(pool, a2s, addr, part, name, col)
    if a2s[addr] then return end
    local slot=claimSlot(pool,addr); if not slot then return end
    slot.part=part; slot.name=name
    slot.lbl.Color=col; slot.tr.Color=col
    if slot.sub then for j=1,MAX_SUB do slot.sub[j].Color=col end end
    a2s[addr]=slot
end
local function cvFree(a2s, addr)
    if not addr then return end
    freeSlot(a2s[addr]); a2s[addr]=nil; invCache[addr]=nil
    partCache[addr]=nil; posCache[addr]=nil
end

setupCvWatchers = function()
    if not CV then return end

    -- Re-wire all live sets through CV now that it's loaded.
    -- wireAll() ran at startup and fell back to safeConnect — CV polling is more
    -- reliable in this executor so we set up the CV versions on top.
    CV:OnChildAdded(WS_Containers, function(obj)
        liveAdd(liveCont, liveContIdx, obj)
        if not ContainerESPEnabled then return end
        local addr=obj and obj.Address; if not addr then return end
        local part=ContainerCfg.getPart(obj)
        if part then
            local slot=claimSlot(POOLS.container,addr)
            if slot then
                slot.part=part; slot.name=obj.Name
                slot.lbl.Color=ContainerColor; slot.tr.Color=ContainerColor
                if slot.sub then for j=1,MAX_SUB do slot.sub[j].Color=ContainerColor end end
                ContainerCfg.a2s[addr]=slot
            end
        end
    end)
    CV:OnChildRemoved(WS_Containers, function(obj)
        liveRem(liveCont, liveContIdx, obj)
        cvFree(ContainerCfg.a2s, obj and obj.Address)
    end)

    CV:OnChildAdded(WS_Dropped, function(obj)
        liveAdd(liveDrop, liveDropIdx, obj)
        if obj:IsA("Model") and obj~=LocalPlayer.Character then
            local hum=obj:FindFirstChildOfClass("Humanoid")
            if hum then
                local hp=0; pcall(function() hp=hum.Health end)
                if hp<=0 then liveAdd(liveDead,liveDeadIdx,obj) end
                -- watch health so corpses auto-enter dead set when they die
                CV:OnPropertyChanged(hum, "Health", function(hp2)
                    if (hp2 or 0) <= 0 then liveAdd(liveDead,liveDeadIdx,obj) end
                end)
            end
        end
        if not DroppedESPEnabled then return end
        local addr=obj and obj.Address; if not addr then return end
        if obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChildWhichIsA("Humanoid") then return end
        local part=findBase(obj)
        if part then
            local slot=claimSlot(POOLS.dropped,addr)
            if slot then
                slot.part=part; slot.name=obj.Name
                slot.lbl.Color=DroppedColor; slot.tr.Color=DroppedColor
                -- CV position watcher for dropped items
                slot.cvConn = CV:OnCFrameChanged(part, function(new)
                    posCache[addr] = V3(new.X, new.Y, new.Z)
                end)
                DroppedCfg.a2s[addr]=slot
            end
        end
    end)
    CV:OnChildRemoved(WS_Dropped, function(obj)
        liveRem(liveDrop,liveDropIdx,obj); liveRem(liveDead,liveDeadIdx,obj)
        cvFree(DroppedCfg.a2s,obj and obj.Address)
        cvFree(DeadCfg.a2s,obj and obj.Address)
    end)

    CV:OnChildAdded(WS_Exits, function(obj)
        liveAdd(liveExits,liveExitsIdx,obj)
        if not ExitESPEnabled then return end
        local addr=obj and obj.Address; if not addr then return end
        local hint=obj:FindFirstChild("Hint"); if not hint then return end
        local part=hint:FindFirstChildOfClass("BasePart") or hint:FindFirstChildWhichIsA("BasePart")
        if part then
            local slot=claimSlot(POOLS.exit,addr)
            if slot then
                slot.part=part; slot.name=obj.Name
                slot.lbl.Color=ExitColor; slot.tr.Color=ExitColor
                ExitCfg.a2s[addr]=slot
            end
        end
    end)
    CV:OnChildRemoved(WS_Exits, function(obj)
        liveRem(liveExits,liveExitsIdx,obj)
        cvFree(ExitCfg.a2s,obj and obj.Address)
    end)

    -- Watch each AiZone for boss spawns and watch boss health to remove on death
    for _,zone in ipairs(WS_AiZones:GetChildren()) do
        -- watch existing bosses' health
        for _,obj in ipairs(zone:GetChildren()) do
            if obj:IsA("Model") then
                local hum=obj:FindFirstChildOfClass("Humanoid")
                if hum then
                    CV:OnPropertyChanged(hum, "Health", function(hp)
                        if (hp or 0) <= 0 then
                            liveRem(liveBoss, liveBossIdx, obj)
                            cvFree(BossCfg.a2s, obj.Address)
                        end
                    end)
                end
            end
        end
        CV:OnChildAdded(zone, function(obj)
            if not obj:IsA("Model") then return end
            local hum=obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChildWhichIsA("Humanoid")
            if hum then
                liveAdd(liveBoss, liveBossIdx, obj)
                -- watch health to remove when dead
                CV:OnPropertyChanged(hum, "Health", function(hp)
                    if (hp or 0) <= 0 then
                        liveRem(liveBoss, liveBossIdx, obj)
                        cvFree(BossCfg.a2s, obj.Address)
                    end
                end)
            end
        end)
        CV:OnChildRemoved(zone, function(obj)
            liveRem(liveBoss, liveBossIdx, obj)
            cvFree(BossCfg.a2s, obj and obj.Address)
        end)
    end
end

