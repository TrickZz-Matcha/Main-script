-- ── POSITION HELPERS ──────────────────────────────────────────────────────────
-- CFrame is now fully supported by the executor so we use CFrame.Position
-- as the primary read. Memory fallback kept for parts that expose Address
-- but not standard Roblox properties.
local MEM_PRIM = 0x148
local MEM_X    = 0xC0 + 0x24
local MEM_Y    = 0xC0 + 0x28
local MEM_Z    = 0xC0 + 0x2C

local function readMemPos(part)
    local ok, r = pcall(function()
        local prim = memory_read("uintptr", part.Address + MEM_PRIM)
        if not prim or prim == 0 then return nil end
        local x = memory_read("float", prim + MEM_X)
        local y = memory_read("float", prim + MEM_Y)
        local z = memory_read("float", prim + MEM_Z)
        if not x or not y or not z then return nil end
        return V3(x, y, z)
    end)
    return ok and r or nil
end

-- Primary: use CFrame.Position (accurate, no memory offsets needed)
-- Fallback: .Position property, then raw memory
local function getPos(part)
    if not part then return nil end
    -- CFrame.Position is the most reliable with full CFrame support
    local ok, cf = pcall(function() return part.CFrame end)
    if ok and cf then return cf.Position end
    -- fallback to .Position
    local ok2, pos = pcall(function() return part.Position end)
    if ok2 and pos then return pos end
    -- last resort: memory read
    return readMemPos(part)
end

local function dsq(a, b)
    local dx, dy, dz = a.X-b.X, a.Y-b.Y, a.Z-b.Z
    return dx*dx + dy*dy + dz*dz
end

