local function findBase(obj)
    return obj:FindFirstChildOfClass("BasePart") or obj:FindFirstChildWhichIsA("BasePart")
end
local function findDescBase(obj)
    for _,v in ipairs(obj:GetDescendants()) do if v:IsA("BasePart") then return v end end
end
local function findBest(obj)
    for _,v in ipairs(obj:GetChildren()) do
        local c=v.ClassName
        if c=="MeshPart" or c=="Part" or c=="UnionOperation" then
            if getPos(v) then return v end
        end
    end
    local best,bestVol=nil,0
    for _,v in ipairs(obj:GetDescendants()) do
        if v:IsA("BasePart") then
            local ok,sz=pcall(function() return v.Size end)
            if ok and sz then
                local vol=sz.X*sz.Y*sz.Z
                if vol>bestVol then bestVol=vol; best=v end
            elseif not best then best=v end
        end
    end
    return best
end

-- ── SCAN ──────────────────────────────────────────────────────────────────────
local function doScan(cfg)
    local a2s  = cfg.a2s
    local pool = cfg.pool

    if not cfg.on then
        for addr, slot in pairs(a2s) do
            freeSlot(slot)
            invCache[addr]=nil; partCache[addr]=nil; posCache[addr]=nil
        end
        tclear(a2s); cfg.cache[1]={}; return
    end

    local myPos
    if _frameHRPValid then
        myPos = _frameMyPos
    else
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        myPos = hrp.Position
    end

    local lim      = cfg.distSq
    local scanLim  = lim * 1.69
    local remLim   = lim * 2.25
    local getCol   = cfg.getCol
    local getPart  = cfg.getPart
    local isStatic = cfg.isStatic

    local objs    = cfg.getObjs()
    -- reuse pre-allocated scratch tables — zero allocation per call
    local nearby  = cfg._nearby
    local newList = cfg._newList
    local newN    = 0

    for i = 1, #objs do
        local obj  = objs[i]
        local addr = obj and obj.Address
        if not addr then continue end

        local cp = posCache[addr]
        if cp and dsq(cp, myPos) > scanLim then continue end

        local slot = a2s[addr]
        local part = slot and slot.part

        -- validate cached part still alive
        if part then
            local ok, par = pcall(function() return part.Parent end)
            if not ok or not par then
                freeSlot(slot); a2s[addr]=nil; slot=nil; part=nil
                posCache[addr]=nil; partCache[addr]=nil
            end
        end

        if not part then
            part = getPart(obj)
            if not part then continue end
        end

        local pos = cp
        if not pos then
            pos = getPos(part)
            if not pos then continue end
            posCache[addr] = pos
        end

        if dsq(pos, myPos) > scanLim then continue end
        if newN >= cfg.max then continue end

        nearby[addr] = true
        newN = newN+1; newList[newN] = obj

        if not slot then
            slot = claimSlot(pool, addr)
            if slot then
                slot.part=part; slot.name=obj.Name
                local col=getCol()
                slot.lbl.Color=col; slot.tr.Color=col
                if slot.sub then for j=1,MAX_SUB do slot.sub[j].Color=col end end
                a2s[addr]=slot

                if CV and not isStatic then
                    slot.cvConn = CV:OnCFrameChanged(part, function(new)
                        posCache[addr] = V3(new.X, new.Y, new.Z)
                    end)
                end
            end
        end

        if cfg.withInv and slot then
            local inv = obj:FindFirstChild("Inventory")
            if inv then
                local ch = inv:GetChildren()
                local ex = invCache[addr]
                if not ex or #ex~=#ch then
                    local t={}; for j=1,#ch do t[j]=ch[j].Name end
                    invCache[addr]=t
                end
                if CV and not slot.invWatched then
                    slot.invWatched = true
                    local function refreshInv()
                        local c=inv:GetChildren()
                        local t={}; for j=1,#c do t[j]=c[j].Name end
                        invCache[addr]=t
                    end
                    CV:OnChildAdded(inv,   function() refreshInv() end)
                    CV:OnChildRemoved(inv, function() refreshInv() end)
                end
            else invCache[addr]=nil end
        end
    end

    -- release out-of-range — also wipe used nearby entries for next call
    for addr, slot in pairs(a2s) do
        if not nearby[addr] then
            local pos = posCache[addr] or (slot.part and getPos(slot.part))
            if not pos or dsq(pos, myPos) > remLim then
                freeSlot(slot); a2s[addr]=nil; invCache[addr]=nil
                if not isStatic then posCache[addr]=nil end
            end
        end
    end

    -- build safe cache into a persistent table on cfg
    local safe  = cfg.cache[1]
    local safeN = 0
    for i = 1, newN do
        local obj=newList[i]; local addr=obj and obj.Address
        if addr and a2s[addr] then safeN=safeN+1; safe[safeN]=obj end
    end
    -- truncate to exact length
    for i = safeN+1, #safe do safe[i]=nil end
    -- wipe scratch tables for next call
    for i = 1, newN do newList[i]=nil end
    for k in pairs(nearby) do nearby[k]=nil end
end

-- ── UPDATE (render) ───────────────────────────────────────────────────────────
local function doUpdate(cfg)
    local a2s = cfg.a2s

    if not cfg.on or not _frameHRPValid or not _RenderCam then
        for _,slot in pairs(a2s) do
            slot.lbl.Visible=false; slot.tr.Visible=false
            if slot.sub then for j=1,MAX_SUB do slot.sub[j].Visible=false end end
        end
        return
    end

    local wts = WorldToScreen
    if not wts then return end

    local myPos    = _frameMyPos
    local lim      = cfg.distSq
    local col      = cfg.getCol()
    local font     = CurrentFont
    local cache    = cfg.cache[1]
    local cacheN   = #cache
    local showD    = ShowDistance
    local showI    = cfg.withInv and ShowItems
    local doTr     = LineTracerEnabled
    local isStatic = cfg.isStatic
    local cx       = _RenderCam.ViewportSize.X * 0.5

    -- reuse pre-allocated clean table — wipe at end
    local clean  = cfg._clean
    local cleanN = 0

    for i = 1, cacheN do
        local obj  = cache[i]
        local addr = obj and obj.Address
        if not addr then continue end

        local slot = a2s[addr]
        if not slot then continue end

        local lbl = slot.lbl
        local tr  = slot.tr
        local sub = slot.sub

        -- get position — no alive check needed; if part is gone getPos returns nil
        -- and we skip gracefully without releasing (scan will clean it up)
        local p = posCache[addr]
        if not p or (not isStatic and not slot.cvConn) then
            local ok, pos = pcall(function() return slot.part.Position end)
            if ok and pos then
                p = pos; posCache[addr] = pos
            elseif not p then
                lbl.Visible=false; tr.Visible=false
                if sub then for j=1,MAX_SUB do sub[j].Visible=false end end
                cleanN=cleanN+1; clean[cleanN]=obj
                continue
            end
        end

        local d = dsq(p, myPos)
        if d > lim then
            lbl.Visible=false; tr.Visible=false
            if sub then for j=1,MAX_SUB do sub[j].Visible=false end end
            cleanN=cleanN+1; clean[cleanN]=obj; continue
        end

        local sp, onScreen = wts(p)
        if not onScreen then
            lbl.Visible=false; tr.Visible=false
            if sub then for j=1,MAX_SUB do sub[j].Visible=false end end
            cleanN=cleanN+1; clean[cleanN]=obj; continue
        end

        cleanN=cleanN+1; clean[cleanN]=obj

        local sx  = sp.X
        local sy  = sp.Y - 20
        local txt = showD and (slot.name.." ["..mfloor(d^0.5).."m]") or slot.name

        if lbl.Color~=col  then lbl.Color=col  end
        if lbl.Font~=font  then lbl.Font=font  end
        if lbl.Text~=txt   then lbl.Text=txt   end
        lbl.Position = V2(sx, sy)
        lbl.Visible  = true

        if doTr then
            tr.From=V2(cx,0); tr.To=V2(sx,sy)
            if tr.Color~=col then tr.Color=col end
            tr.Visible=true
        else
            tr.Visible=false
        end

        if sub then
            if showI then
                local inv=invCache[addr] or {}; local invN=#inv
                for j=1,MAX_SUB do
                    local s=sub[j]
                    if j<=invN then
                        local t2="- "..inv[j]
                        if s.Text~=t2   then s.Text=t2   end
                        if s.Color~=col then s.Color=col end
                        if s.Font~=font then s.Font=font end
                        s.Position=V2(sx, sy+j*16); s.Visible=true
                    else s.Visible=false end
                end
            else
                for j=1,MAX_SUB do sub[j].Visible=false end
            end
        end
    end

    -- copy clean back into cache, truncate extra entries
    local cacheOut = cfg.cache[1]
    for i = 1, cleanN do cacheOut[i] = clean[i] end
    for i = cleanN+1, cacheN do cacheOut[i] = nil end
    -- wipe scratch table for next frame
    for i = 1, cleanN do clean[i] = nil end
end

-- ── LIVE SETS ─────────────────────────────────────────────────────────────────
-- Populated once at startup, kept in sync by events.
-- getObjs() returns the table reference directly — zero allocation per tick.
local liveCont    = {}; local liveContIdx = {}
local liveDrop    = {}; local liveDropIdx = {}
local liveDead    = {}; local liveDeadIdx = {}
local liveExits   = {}; local liveExitsIdx = {}
local liveBoss    = {}; local liveBossIdx  = {}

local function liveAdd(arr, idx, obj)
    local addr = obj and obj.Address
    if not addr or idx[addr] then return end
    local n = #arr+1; arr[n]=obj; idx[addr]=n
end
local function liveRem(arr, idx, obj)
    local addr = obj and obj.Address; if not addr then return end
    local pos = idx[addr]; if not pos then return end
    local last = #arr
    if pos~=last then
        local m=arr[last]; arr[pos]=m; idx[m.Address]=pos
    end
    arr[last]=nil; idx[addr]=nil
end

local function safeConnect(sig, fn)
    pcall(function() sig:Connect(fn) end)
end

-- wire(parent, addFn, remFn) — uses CV if loaded, safeConnect otherwise
local function wire(parent, addFn, remFn)
    if CV then
        CV:OnChildAdded(parent,   addFn)
        CV:OnChildRemoved(parent, remFn)
    else
        safeConnect(parent.ChildAdded,   addFn)
        safeConnect(parent.ChildRemoved, remFn)
    end
end

local function wireAll()
    -- Containers (static)
    for _,obj in ipairs(WS_Containers:GetChildren()) do liveAdd(liveCont, liveContIdx, obj) end
    wire(WS_Containers,
        function(obj) liveAdd(liveCont, liveContIdx, obj) end,
        function(obj) liveRem(liveCont, liveContIdx, obj) end)

    -- DroppedItems (items + corpses)
    for _,obj in ipairs(WS_Dropped:GetChildren()) do
        liveAdd(liveDrop, liveDropIdx, obj)
        if obj:IsA("Model") and obj~=LocalPlayer.Character then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum then local hp=0; pcall(function() hp=hum.Health end)
                if hp<=0 then liveAdd(liveDead, liveDeadIdx, obj) end
            end
        end
    end
    wire(WS_Dropped,
        function(obj)
            liveAdd(liveDrop, liveDropIdx, obj)
            if obj:IsA("Model") and obj~=LocalPlayer.Character then
                local hum = obj:FindFirstChildOfClass("Humanoid")
                if hum then local hp=0; pcall(function() hp=hum.Health end)
                    if hp<=0 then liveAdd(liveDead, liveDeadIdx, obj) end
                end
            end
        end,
        function(obj)
            liveRem(liveDrop, liveDropIdx, obj)
            liveRem(liveDead, liveDeadIdx, obj)
        end)

    -- Exits (static)
    for _,obj in ipairs(WS_Exits:GetChildren()) do liveAdd(liveExits, liveExitsIdx, obj) end
    wire(WS_Exits,
        function(obj) liveAdd(liveExits, liveExitsIdx, obj) end,
        function(obj) liveRem(liveExits, liveExitsIdx, obj) end)

    -- Bosses (nested: AiZones > Zone > Model)
    for _,zone in ipairs(WS_AiZones:GetChildren()) do
        for _,obj in ipairs(zone:GetChildren()) do
            if obj:IsA("Model") and
               (obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChildWhichIsA("Humanoid")) then
                liveAdd(liveBoss, liveBossIdx, obj)
            end
        end
        wire(zone,
            function(obj)
                if obj:IsA("Model") and
                   (obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChildWhichIsA("Humanoid")) then
                    liveAdd(liveBoss, liveBossIdx, obj)
                end
            end,
            function(obj) liveRem(liveBoss, liveBossIdx, obj) end)
    end
    -- also watch for new AiZone folders being added
    wire(WS_AiZones,
        function(zone)
            wire(zone,
                function(obj)
                    if obj:IsA("Model") and
                       (obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChildWhichIsA("Humanoid")) then
                        liveAdd(liveBoss, liveBossIdx, obj)
                    end
                end,
                function(obj) liveRem(liveBoss, liveBossIdx, obj) end)
        end,
        function() end)
end

