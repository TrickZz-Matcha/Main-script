-- This is the fix for label jitter: RenderStepped is called by the engine
-- immediately before each frame is rendered, so Drawing updates always happen
-- at exactly the right moment.
local OriginalFOV = 90

RunService.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    if cam then _RenderCam=cam; StaticCam=cam end

    if cam then
        if ZoomEnabled then
            if cam.FieldOfView~=10 then cam.FieldOfView=10 end
        elseif CameraFOVEnabled then
            if cam.FieldOfView~=FOVAmount then cam.FieldOfView=FOVAmount end
        end
    end

    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        _frameMyPos=hrp.Position; _frameHRPValid=true
    else
        _frameHRPValid=false
    end

    if not _RenderCam then return end

    if ContainerESPEnabled then doUpdate(ContainerCfg) end
    if DroppedESPEnabled   then doUpdate(DroppedCfg)   end
    if DeadBodyESPEnabled  then doUpdate(DeadCfg)      end
    if ExitESPEnabled      then doUpdate(ExitCfg)      end
    if BossESPEnabled      then doUpdate(BossCfg)      end
end)

