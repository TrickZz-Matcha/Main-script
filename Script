-- ── SLOT POOL ─────────────────────────────────────────────────────────────────
-- All Drawing objects created ONCE. Never Drawing.new/Remove again.
local MAX_SUB = 4
local BUDGETS = { container=5, dropped=5, dead=5, exit=3, boss=7 }

local function makePool(n, withSub)
    local pool = {}
    for i = 1, n do
        local lbl = Drawing.new("Text")
        lbl.Outline=true; lbl.Center=true; lbl.Visible=false
        lbl.Font=CurrentFont; lbl.Size=14; lbl.Text=""; lbl.Color=Color3.new(1,1,1)
        local tr = Drawing.new("Line")
        tr.Thickness=1; tr.Visible=false; tr.Color=Color3.new(1,1,1)
        local sub = nil
        if withSub then
            sub = {}
            for j = 1, MAX_SUB do
                local s = Drawing.new("Text")
                s.Outline=true; s.Center=true; s.Visible=false
                s.Font=CurrentFont; s.Size=11; s.Text=""; s.Color=Color3.new(1,1,1)
                sub[j] = s
            end
        end
        pool[i] = { lbl=lbl, tr=tr, sub=sub, addr=nil, part=nil, name=nil, cvConn=nil }
    end
    return pool
end

local POOLS = {
    container = makePool(BUDGETS.container, true),
    dropped   = makePool(BUDGETS.dropped,  false),
    dead      = makePool(BUDGETS.dead,     false),
    exit      = makePool(BUDGETS.exit,     false),
    boss      = makePool(BUDGETS.boss,     false),
}

local function claimSlot(pool, addr)
    for i = 1, #pool do
        if not pool[i].addr then pool[i].addr=addr; return pool[i] end
    end
end

local function freeSlot(slot)
    if not slot then return end
    -- disconnect CV position watcher if one was set up
    if slot.cvConn then
        pcall(function() slot.cvConn:Disconnect() end)
        slot.cvConn = nil
    end
    slot.addr=nil; slot.part=nil; slot.name=nil
    slot.lbl.Visible=false; slot.tr.Visible=false
    if slot.sub then for j=1,MAX_SUB do slot.sub[j].Visible=false end end
end

