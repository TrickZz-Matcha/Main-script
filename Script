local PREFIXES = {
    {"DFFlag","bool"},{"FFlag","bool"},{"DFInt","int"},{"FInt","int"},
    {"DFLog","int"},{"FLog","int"},{"DFString","string"},{"FString","string"},
}
local function parseJson(s)
    local t={}; for k,v in s:gmatch('"([^"]+)"%s*:%s*"?([^",\n}]+)"?') do t[k]=v:match("^%s*(.-)%s*$") end; return t
end
local function stripPfx(n)
    for i=1,#PREFIXES do local p=PREFIXES[i][1]; if n:sub(1,#p)==p then return n:sub(#p+1) end end; return n
end
local function typeVal(n,v)
    for i=1,#PREFIXES do local p,t=PREFIXES[i][1],PREFIXES[i][2]
        if n:sub(1,#p)==p then
            if t=="bool" then return t,(v=="True"or v=="true"or v=="1")
            elseif t=="int" then return t,tonumber(v) else return t,v end
        end
    end
end
local function parseFFlags(d)
    for line in d:gmatch("[^\r\n]+") do
        local n,off=line:match("uintptr_t%s+([%w_]+)%s*=%s*0x([%x]+)")
        if n and off then FFlags[n]=tonumber(off,16) end
    end
end
local function setFF(n,t,v)
    local a=FFlags[n]; if not a then return false end
    if t=="string" then return false end  -- string memory_write signature differs, skip
    pcall(function()
        if t=="bool" then memory_write("byte",Base+a,v and 1 or 0)
        elseif t=="int" then memory_write("int",Base+a,v) end
    end); return true
end
local function getFF(n,t)
    local a=FFlags[n]; if not a then return nil end
    if t=="string" then return nil end
    local ok,r=pcall(function()
        if t=="bool" then return memory_read("byte",Base+a)==1
        elseif t=="int" then return memory_read("int",Base+a) end
    end); return ok and r or nil
end
do local ok,r=pcall(function() return game:HttpGet("https://offsets.ntgetwritewatch.workers.dev/FFlags.hpp") end)
   if ok and r then parseFFlags(r) end end

local netOrig, fpsOrig = {}, {}
local function applyFS(json,orig,tag)
    local n=0
    for full,val in pairs(parseJson(json)) do
        local name=stripPfx(full); local typ,pv=typeVal(full,val)
        if typ and pv~=nil then
            if not orig[name] then local ov=getFF(name,typ); if ov~=nil then orig[name]={Type=typ,Value=ov} end end
            if setFF(name,typ,pv) then n=n+1 end
        end
    end
    notify("Applied "..n.." "..tag.." FFlags","Matcha",3)
end
local function revertFS(orig,tag)
    local n=0; for name,d in pairs(orig) do if setFF(name,d.Type,d.Value) then n=n+1 end end
    tclear(orig); notify("Reverted "..n.." "..tag.." FFlags","Matcha",3)
end
