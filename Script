        local cd = 0
        while true do
            task.wait(0.1)
            cd=cd-1; if cd<=0 then rebuildActive(); cd=20 end
            local n=#active; if n==0 then continue end
            for i=1,n do
                local b=active[i]; local v=b.kb:IsEnabled()
                if v~=b.get() then b.set(v); UI.SetValue(b.id,v) end
            end
        end
