    function() BossCfg.distSq=BOSS_DIST_SQ      end,
}

RunService.Heartbeat:Connect(function(dt)
    for i = 1, 5 do
        _scanTimers[i] = _scanTimers[i] + dt
        if _scanTimers[i] >= SCAN_INTERVALS[i] then
            _scanTimers[i] = 0
            _scanDistSqs[i]()
            if _scanEnabled[i]() then doScan(_scanCfgs[i]) end
        end
    end
end)

